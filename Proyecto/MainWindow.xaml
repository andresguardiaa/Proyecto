<Window x:Class="Proyecto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Dropium Login"
        Width="320"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#374151">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="2.5*" />
            <RowDefinition Height="4*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- Logo con título separado -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" >
            <!-- Logo gota con degradado -->
            <Grid Width="80" Height="100" Margin="0,0,0,10">
                <Path Data="M40,0 L80,100 L0,100 Z" Stretch="Fill" >
                    <Path.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7BC68E" Offset="0"/>
                            <GradientStop Color="#44C5F5" Offset="1"/>
                        </LinearGradientBrush>
                    </Path.Fill>
                </Path>
            </Grid>

            <!-- Texto DROPIUM separado y centrado -->
            <TextBlock Text="DROPIUM"
                       Foreground="#9CA3AF"
                       FontSize="20"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />
        </StackPanel>

        <!-- Campos formulario -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- Username -->
            <Border Background="White" CornerRadius="25" Height="45" Margin="0,0,0,15">
                <TextBox materialDesign:HintAssist.Hint="Username"
                         Padding="20,0,0,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="16"
                         BorderBrush="Transparent"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#9CA3AF"
                         VerticalContentAlignment="Center"/>
            </Border>

            <!-- Password -->
            <Border Background="White" CornerRadius="25" Height="45" Margin="0,0,0,15">
                <PasswordBox materialDesign:HintAssist.Hint="Password"
                             Padding="20,0,0,0"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             FontSize="16"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#9CA3AF"
                             VerticalContentAlignment="Center"/>
            </Border>

            <!-- Botón con esquinas redondeadas mediante ControlTemplate -->
            <Button Content="Log In"
                    Height="45"
                    FontSize="16"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Padding="0"
                    Margin="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7BC68E" Offset="0"/>
                        <GradientStop Color="#44C5F5" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </StackPanel>

        <!-- Texto 'Forgot your password?' -->
        <TextBlock Grid.Row="2"
                   Text="Forgot your password?"
                   FontSize="14"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Center"
                   Margin="0,30,0,0" />
    </Grid>
</Window>
