<Window x:Class="Proyecto.Dialogos.AgregarProyecto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto.Dialogos"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"        
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="AgregarProyecto" Height="450" Width="800"
        x:Name="diagAgregarProyecto"
        Loaded="diagAgregarProyecto_Loaded">
    <DockPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="15*" />
                <RowDefinition Height="10*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*"/>
                <ColumnDefinition Width="50*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#374151" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" >
                <TextBlock Text="Agregar Proyectos" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="26" TextAlignment="Center"/>
            </Border>
            <TextBlock Text="Los campos en negrita son obligatorios*" Grid.Column="0" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="16" FontWeight="Bold" Grid.Row="1"/>
            <TextBox 
                Grid.Row="2" 
                Text="{Binding proyecto.Nombre}"
                Grid.Column="0" 
                Margin="20,15,20,15" 
                Foreground="Black" 
                FontSize="16" 
                FontWeight="Bold" 
                Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                materialDesign:HintAssist.Hint="Nombre Proyecto*" 
                x:Name="txtNombreProyecto"/>
            <ComboBox 
                x:Name="cmbCliente" 
                SelectedItem="{Binding proyecto.ClienteIdClienteNavigation}" 
                ItemsSource="{Binding listaClientes}" 
                DisplayMemberPath="Nombre"
                Grid.Row="2" 
                Grid.Column="1" 
                Margin="20,15,20,0" 
                Foreground="Black" 
                FontSize="16" 
                FontWeight="Bold" 
                Style="{StaticResource MaterialDesignFloatingHintComboBox}" 
                materialDesign:HintAssist.Hint="Cliente*"/>

            <DatePicker 
                Grid.Column="0"
                Grid.Row="3"
                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                SelectedDate="{Binding proyecto.FechaInicio}"
                materialDesign:HintAssist.Hint="Fecha de Inicio*"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Margin="20,20,20,20" />

            <DatePicker 
                Grid.Column="1"
                Grid.Row="3"
                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                SelectedDate="{Binding proyecto.FechaFin}"
                materialDesign:HintAssist.Hint="Fecha de Fin*"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Margin="20,20,20,20" />


            <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
                <Button Background="Transparent" x:Name="btnCancelarProyecto" Click="btnCancelarProyecto_Click"  Content="Cancelar" Margin="80,0,20,0" BorderBrush="DarkGray"/>
                <Button Content="Guardar" Background="#374151" Foreground="White" x:Name="btnGuardarProyecto" Click="btnGuardarProyecto_Click"  Margin="20,0,80,0" BorderBrush="Transparent" />
            </StackPanel>

        </Grid>
    </DockPanel>
</Window>
