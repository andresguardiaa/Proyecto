<UserControl x:Class="Proyecto.UC.UCDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"        
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:local="clr-namespace:Proyecto.UC"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="ucDashboard"
             Loaded="ucDashboard_Loaded">
    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="20,10,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="¡Hola de nuevo: " FontSize="26" FontWeight="Bold" Foreground="#374151"/>
                <TextBlock Text="{Binding NombreUsuario}" FontSize="26" FontWeight="Bold" Foreground="#374151"/>
                <TextBlock Text="!" FontSize="26" FontWeight="Bold" Foreground="#374151"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignToolButton}" 
                        ToolTip="Refrescar datos" 
                        x:Name="btnRefrescar"
                        Click="btnRefrescar_Click" 
                        Margin="0,0,15,0"
                        Foreground="#374151">
                    <materialDesign:PackIcon Kind="Refresh" Width="25" Height="25"/>
                </Button>

                <materialDesign:PackIcon Kind="ClockOutline" Width="25" Height="25" Foreground="#374151" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HoraActual}" FontSize="20" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <Grid Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <UniformGrid Grid.Row="0" Columns="4" Rows="1" Margin="0,0,0,20">

                <materialDesign:Card Margin="0,0,10,0" Padding="15" UniformCornerRadius="8" Foreground="White">
                    <materialDesign:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0.0" />
                            <GradientStop Color="#374151" Offset="1.0" />
                        </LinearGradientBrush>
                    </materialDesign:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PROYECTOS" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="{Binding KpiProyectos}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="BriefcaseOutline" Width="40" Height="40" Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Margin="10,0,10,0" Padding="15" UniformCornerRadius="8" Foreground="White">
                    <materialDesign:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#14B8A6" Offset="0.0" />
                            <GradientStop Color="#374151" Offset="1.0" />
                        </LinearGradientBrush>
                    </materialDesign:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PLANTILLA" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="{Binding KpiPlantillaActiva}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="AccountGroupOutline" Width="40" Height="40" Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Margin="10,0,10,0" Padding="15" UniformCornerRadius="8" Foreground="White">
                    <materialDesign:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6366F1" Offset="0.0" />
                            <GradientStop Color="#374151" Offset="1.0" />
                        </LinearGradientBrush>
                    </materialDesign:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BALANCE MES" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="{Binding KpiBalance}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="TrendingUp" Width="40" Height="40" Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Margin="10,0,0,0" Padding="15" UniformCornerRadius="8" Foreground="White">
                    <materialDesign:Card.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6B7280" Offset="0.0" />
                            <GradientStop Color="#374151" Offset="1.0" />
                        </LinearGradientBrush>
                    </materialDesign:Card.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MÁQUINAS" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="{Binding KpiMaquinasOperativas}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="Excavator" Width="40" Height="40" Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:Card>

            </UniformGrid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Column="0" Grid.Row="0" Margin="0,0,10,10" UniformCornerRadius="8">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Evolución Financiera (Últimos 6 meses)" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>

                        <lvc:CartesianChart Grid.Row="1" 
                                            Series="{Binding SeriesFinanzas}" 
                                            XAxes="{Binding XAxesFinanzas}" 
                                            LegendPosition="Top" />
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Margin="10,0,10,10" UniformCornerRadius="8">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Horas Estimadas vs Invertidas por Proyecto Activo" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>

                        <lvc:CartesianChart Grid.Row="1" 
                                    Series="{Binding SeriesProyectos}" 
                                    XAxes="{Binding XAxesProyectos}" 
                                    LegendPosition="Right" />
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,0" UniformCornerRadius="8">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Costo Total Operativo por Trabajador" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>

                        <lvc:CartesianChart Grid.Row="1" 
                            Series="{Binding SeriesCostoTrabajador}" 
                            XAxes="{Binding XAxesCostoTrabajador}" 
                            LegendPosition="Right" />
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Grid.Row="1" Margin="10,0,10,0" UniformCornerRadius="8">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Estado de Máquinas" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>
                        <lvc:PieChart Grid.Row="1" Series="{Binding SeriesProductividad}" LegendPosition="Bottom" />
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!--<Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Width="350" Margin="20,0,0,0" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" Grid.RowSpan="2" Height="350"  UniformCornerRadius="8">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Estado de Máquinas" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#374151" />

                    <lvc:PieChart Grid.Row="1" Series="{Binding SeriesProductividad}" LegendPosition="Bottom" />
                </Grid>
            </materialDesign:Card>
        </Grid>-->
    </DockPanel>
</UserControl>
