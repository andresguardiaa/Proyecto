<UserControl x:Class="Proyecto.UC.UCVerGastos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Proyecto.UC"
             mc:Ignorable="d" 
             x:Name="ListadoGastos"
             Loaded="ListadoGastos_Loaded"
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <Grid DockPanel.Dock="Top">
            <StackPanel>
                <TextBlock Text="Listado de Gastos" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <CheckBox 
                              Content="Nóminas"
                              VerticalContentAlignment="Center"
                              Margin="10,10,10,10"
                              Style="{StaticResource MaterialDesignCheckBox}"
                              IsChecked="{Binding filtroNominaActivo}">
                        <CheckBox.Resources>
                            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#374151" />

                            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="LimeGreen" />
                        </CheckBox.Resources>

                    </CheckBox>

                    <TextBlock Text="Ver desde:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding FechaInicioFiltro}" Width="150" Margin="0,0,10,0" />

                    <TextBlock Text="Ver hasta:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding FechaFinFiltro}" Width="150" Margin="0,0,10,0" />

                    <Button Content="Filtrar" Background="#374151" Foreground="White" BorderBrush="Transparent" x:Name="btnFiltrar" Click="btnFiltrar_Click" Margin="0,0,10,0" Width="80"/>
                    <Button Content="Limpiar" BorderBrush="#374151" Foreground="#374151" x:Name="btnLimpiar" Click="btnLimpiar_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80"/>

                    <TextBlock Text="Total:" FontWeight="Bold" FontSize="20" VerticalAlignment="Center" Foreground="#374151" Margin="10,0,5,0"/>
                    <TextBlock Text="{Binding TotalGastos, StringFormat=\{0:N2\} €}" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="#374151"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid>
            <DataGrid ItemsSource="{Binding listaGastosFiltro}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      ColumnWidth="*">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cantidad (€)" Binding="{Binding Cantidad}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Máquina" Binding="{Binding NombreModelo}" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Fecha">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding Fecha}" IsEnabled="False"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
