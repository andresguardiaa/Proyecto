<UserControl x:Class="Proyecto.UC.UCVerIngresos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Proyecto.UC"
             mc:Ignorable="d"
             x:Name="ListadoIngresos"
             Loaded="ListadoIngresos_Loaded"
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <Grid DockPanel.Dock="Top">
            <StackPanel>
                <TextBlock Text="Listado de ingresos" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="Ver desde:" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <DatePicker SelectedDate="{Binding FechaFiltro}" Width="150" Margin="0,0,10,0" />

                    <Button Content="Filtrar" Background="#374151" Foreground="White" BorderBrush="Transparent" x:Name="btnFiltrar" Click="btnFiltrar_Click" Margin="0,0,10,0" Width="80"/>
                    <Button Content="Limpiar" BorderBrush="#374151" Foreground="#374151" x:Name="btnLimpiar" Click="btnLimpiar_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid>
            <DataGrid ItemsSource="{Binding listaFacturasFiltro}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  ColumnWidth="*">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Proyecto" Binding="{Binding ProyectosIdProyectoNavigation.Nombre}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Total}" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Fecha">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding Fecha}" IsEnabled="False"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
