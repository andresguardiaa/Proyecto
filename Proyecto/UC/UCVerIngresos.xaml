<UserControl x:Class="Proyecto.UC.UCVerIngresos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Proyecto.UC"
             mc:Ignorable="d"
             x:Name="ListadoIngresos"
             Loaded="ListadoIngresos_Loaded"
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <Grid DockPanel.Dock="Top">
            <TextBlock Text="Listado de Ingresos" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>
        </Grid>
        <Grid>
            <DataGrid ItemsSource="{Binding facturaList}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  ColumnWidth="*">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Proyecto" Binding="{Binding ProyectosIdProyectoNavigation.Nombre}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Total}" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Fecha">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding Fecha}" IsEnabled="False"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
