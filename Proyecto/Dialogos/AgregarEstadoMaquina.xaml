<Window x:Class="Proyecto.Dialogos.AgregarEstadoMaquina"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto.Dialogos"
        mc:Ignorable="d"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"        
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="AgregarMaquina" Height="200" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        x:Name="diagAgregarModelo"
        UseLayoutRounding="True" 
        SnapsToDevicePixels="True">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0" Background="#374151">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                <materialDesign:PackIcon Kind="WindowMinimize" x:Name="btnMin" Width="20" Height="20" Cursor="Hand" MouseLeftButtonUp="btnMin_MouseLeftButtonUp" Foreground="White"/>
                <materialDesign:PackIcon Kind="WindowMaximize" x:Name="btnMax" Width="20" Height="20"  Cursor="Hand" MouseLeftButtonUp="btnMax_MouseLeftButtonUp" Foreground="White"/>
                <materialDesign:PackIcon Kind="WindowClose" x:Name="btnClose"  Width="20" Height="20" Cursor="Hand" MouseLeftButtonUp="btnClose_MouseLeftButtonUp" Foreground="White"/>
            </StackPanel>
        </Grid>
        <DockPanel Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="15*" />
                    <RowDefinition Height="15*"/>

                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*"/>
                    <ColumnDefinition Width="50*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#374151" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" >
                    <TextBlock Text="Agregar Estado de Máquina" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="26" TextAlignment="Center"/>
                </Border>

                <TextBox 
                    Grid.Row="2" 
                    Text="{Binding estado.Descripcion}"
                    Grid.Column="0" 
                    Margin="20,15,20,15" 
                    Foreground="Black" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                    materialDesign:HintAssist.Hint="Estado" 
                    x:Name="txtTarifaMaquina"/>

                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button Background="Transparent" x:Name="btnCancelarEstado" Click="btnCancelarEstado_Click"  Content="Cancelar" Margin="80,0,20,0" BorderBrush="DarkGray"/>
                    <Button Content="Guardar" Background="#374151" Foreground="White" x:Name="btnGuardarEstado" Click="btnGuardarEstado_Click"  Margin="20,0,80,0" BorderBrush="Transparent" />
                </StackPanel>

            </Grid>
        </DockPanel>
    </Grid>
</Window>
