<Window x:Class="Proyecto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Proyecto"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Grid DockPanel.Dock="Left" Background="#374151" Width="200" >
            <StackPanel>
                <Grid>
                    <!-- Definimos el titulo del panel -->
                    <materialDesign:PackIcon Kind="ViewDashboard" Width="15" Height="15" Margin="10 16" Foreground="White"/>
                    <!-- Ahora utilizamos este control que ns muestra un elemento de la lista -->
                    <ListBoxItem x:Name="ListViewItemMenu" Content="Dashboard" Padding="37 14" FontSize="15" Foreground="White" Style="{StaticResource MaterialDesignListBoxItem}"/>
                </Grid>
                <Grid>
                    <materialDesign:PackIcon Kind="Account" Foreground="White" Width="20" Height="20" Margin="8 15" />
                    <Expander Header="Usuarios" IsExpanded="False" Background="Transparent" Width="170" Foreground="White" Style="{StaticResource MaterialDesignExpander}">
                        <ListView ItemsSource="{Binding Path=SubItems}" Foreground="White" Style="{StaticResource MaterialDesignListView}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListViewItem Content="Añadir" Padding="40,10,0,10"/>
                            <ListViewItem Content="Editar" Padding="40,10,0,10"/>
                            <ListViewItem Content="Borrar" Padding="40,10,0,10"/>
                        </ListView>
                    </Expander>

                </Grid>
                <Grid>
                    <materialDesign:PackIcon Kind="Account" Foreground="White" Width="20" Height="20" Margin="8 15" />
                    <Expander Header="Usuarios" IsExpanded="False" Background="Transparent" Width="170" Foreground="White" Style="{StaticResource MaterialDesignExpander}">
                        <ListView ItemsSource="{Binding Path=SubItems}" Foreground="White" Style="{StaticResource MaterialDesignListView}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListViewItem Content="Añadir" Padding="40,10,0,10"/>
                            <ListViewItem Content="Editar" Padding="40,10,0,10"/>
                            <ListViewItem Content="Borrar" Padding="40,10,0,10"/>
                        </ListView>
                    </Expander>

                </Grid>
            </StackPanel>

        </Grid>
        <Grid>
            
        </Grid>
    </DockPanel>
</Window>
