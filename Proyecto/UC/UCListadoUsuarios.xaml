<UserControl x:Class="Proyecto.UC.UCListadoUsuarios"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Proyecto.UC"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="ucListadoUsuarios"
             Loaded="ucListadoUsuarios_Loaded">
    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="20,10,20,10">
            <StackPanel>
                <TextBlock Text="Listado de Trabajadores" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Style="{StaticResource MaterialDesignToolButton}" 
                        ToolTip="Refrescar lista" 
                        x:Name="btnRefrescar"
                        Click="btnRefrescar_Click" 
                        Foreground="#374151">
                    <materialDesign:PackIcon Kind="Refresh" Width="25" Height="25"/>
                </Button>

                <!-- <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="Ver desde:" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <DatePicker SelectedDate="{Binding FechaFacturaFiltro}" Width="150" Margin="0,0,10,0" />

                    <Button Content="Filtrar" Background="#374151" Foreground="White" BorderBrush="Transparent" x:Name="btnFiltrar" Click="btnFiltrar_Click" Margin="0,0,10,0" Width="80"/>
                    <Button Content="Limpiar" BorderBrush="#374151" Foreground="#374151" x:Name="btnLimpiar" Click="btnLimpiar_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80"/>
                </StackPanel>-->
            </StackPanel>
        </Grid>
        <Grid>
            <DataGrid ItemsSource="{Binding listaTrabajadores}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              ColumnWidth="*"
              SelectedItem="{Binding trabajadorSeleccionado}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Nombre y apellidos" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Nombre}"/>
                                    <TextBlock Text=" "/>
                                    <TextBlock Text="{Binding Apellido1}"/>
                                    <TextBlock Text=" "/>
                                    <TextBlock Text="{Binding Apellido2}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Dirección">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ciudad: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Ciudad}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Calle: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Calle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="CP: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Cp}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Editar">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="btnEditarUsuario" Click="btnEditarUsuario_Click" Foreground="White" BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Editar" Margin="10,0,10,0"/>
                                        <materialDesign:PackIcon Kind="Edit"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Dar de Baja">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="btnEliminarUsuario" Click="btnEliminarUsuario_Click" Foreground="White" BorderBrush="Transparent" Background="#f54e42">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Dar de Baja" Margin="10,0,10,0"/>
                                        <materialDesign:PackIcon Kind="Trash"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
